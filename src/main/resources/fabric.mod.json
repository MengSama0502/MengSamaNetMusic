{
  "schemaVersion": 1,
  "id": "mengsamanetmusic",
  "version": "${version}",
  "name": "MengSama Net Music",
  "description": "A comprehensive music player mod integrating NetEase Cloud Music, QQ Music and local playback.",
  "authors": [
    "MengSama0502",
    "niumadadi520",
    "YuZiJiang"
  ],
  "contact": {
    "homepage": "https://github.com/MengSama0502/MengSamaNetMusic"
  },
  "license": "MIT",
  "icon": "assets/mengsamanetmusic/textures/item/mod_icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.mengsama.mod.mengsamanetmusic.MengSamaNetMusic"
    ],
    "client": [
      "com.mengsama.mod.mengsamanetmusic.client.ClientModEvents"
    ]
